---
const currentYear = new Date().getFullYear();

const footerLinks = {
  company: [
    { href: '/about', label: 'About' },
    { href: '/services', label: 'Services' },
    { href: '/contact', label: 'Contact' },
  ],
  resources: [
    { href: '/blog', label: 'Insights' },
  ],
};
---

<footer class="border-t border-ns-border bg-ns-bg-deep" role="contentinfo">
  <div class="content-container py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">
      <!-- Brand Column -->
      <div class="md:col-span-5">
        <a href="/" class="flex items-center gap-3 mb-6" aria-label="Northsake - Home">
          <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M16 4L16 28" stroke="#c8a55c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M16 4L20 10" stroke="#c8a55c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M16 4L12 10" stroke="#c8a55c" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="16" cy="16" r="10" stroke="#1a2235" stroke-width="1"/>
          </svg>
          <span class="font-sans text-sm font-semibold tracking-[0.25em] uppercase text-ns-text">Northsake</span>
        </a>
        <p class="text-ns-text-secondary text-sm leading-relaxed max-w-sm">
          AI visibility infrastructure for consulting firms. We help you get found on Google and get cited by AI engines.
        </p>
      </div>

      <!-- Links -->
      <div class="md:col-span-3 md:col-start-7">
        <h3 class="font-mono text-xs tracking-widest-plus uppercase text-ns-text-secondary mb-6">Company</h3>
        <ul class="space-y-4">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-ns-text hover:text-ns-accent transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-3">
        <h3 class="font-mono text-xs tracking-widest-plus uppercase text-ns-text-secondary mb-6">Resources</h3>
        <ul class="space-y-4">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-ns-text hover:text-ns-accent transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-ns-border flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-ns-text-secondary">
        &copy; {currentYear} Northsake. All rights reserved.
      </p>
      <p class="text-xs text-ns-text-secondary">
        Get found on Google. Get cited by AI.
      </p>
    </div>
  </div>
</footer>
