---
const { pathname } = Astro.url;

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/blog', label: 'Insights' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <div class="content-container">
    <div class="flex items-center justify-between h-20 border-b border-ns-border/50">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="Northsake - Home">
        <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="transition-transform duration-300 group-hover:-translate-y-0.5" aria-hidden="true">
          <path d="M16 4L16 28" stroke="#c8a55c" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 4L20 10" stroke="#c8a55c" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M16 4L12 10" stroke="#c8a55c" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="16" cy="16" r="10" stroke="#1a2235" stroke-width="1"/>
        </svg>
        <span class="font-sans text-sm font-semibold tracking-[0.25em] uppercase text-ns-text">Northsake</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-10" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm tracking-wide transition-colors duration-200',
              pathname === link.href || pathname.startsWith(link.href + '/')
                ? 'text-ns-accent'
                : 'text-ns-text-secondary hover:text-ns-text',
            ]}
            aria-current={pathname === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
        <a href="/contact" class="btn-primary text-xs py-3 px-6">Get Your NorthScore</a>
      </nav>

      <!-- Mobile Menu Toggle -->
      <button
        class="md:hidden flex flex-col gap-1.5 p-2"
        id="mobile-menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="w-6 h-px bg-ns-text transition-all duration-300" id="burger-top"></span>
        <span class="w-6 h-px bg-ns-text transition-all duration-300" id="burger-mid"></span>
        <span class="w-4 h-px bg-ns-text transition-all duration-300 ml-auto" id="burger-bot"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 top-20 bg-ns-bg/98 backdrop-blur-sm z-40 translate-x-full transition-transform duration-300"
    aria-hidden="true"
  >
    <nav class="content-container pt-12 flex flex-col gap-8" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-2xl font-display transition-colors duration-200',
            pathname === link.href ? 'text-ns-accent' : 'text-ns-text hover:text-ns-accent',
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="pt-4 border-t border-ns-border">
        <a href="/contact" class="btn-primary w-full justify-center">Get Your NorthScore</a>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-20"></div>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const burgerTop = document.getElementById('burger-top');
  const burgerMid = document.getElementById('burger-mid');
  const burgerBot = document.getElementById('burger-bot');
  let isOpen = false;

  // Header background on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      header?.classList.add('bg-ns-bg/95', 'backdrop-blur-md');
    } else {
      header?.classList.remove('bg-ns-bg/95', 'backdrop-blur-md');
    }
  });

  // Mobile menu toggle
  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu?.classList.remove('translate-x-full');
      menu?.setAttribute('aria-hidden', 'false');
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', 'Close menu');
      burgerTop?.classList.add('rotate-45', 'translate-y-[3.5px]');
      burgerMid?.classList.add('opacity-0');
      burgerBot?.classList.add('-rotate-45', '-translate-y-[3.5px]', 'w-6');
      document.body.style.overflow = 'hidden';
    } else {
      menu?.classList.add('translate-x-full');
      menu?.setAttribute('aria-hidden', 'true');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
      burgerTop?.classList.remove('rotate-45', 'translate-y-[3.5px]');
      burgerMid?.classList.remove('opacity-0');
      burgerBot?.classList.remove('-rotate-45', '-translate-y-[3.5px]', 'w-6');
      document.body.style.overflow = '';
    }
  });
</script>
